TELEGRAM_BOT_TOKEN=
# Compose deployment can pin a release tag or digest for deterministic rollback.
# BOT_IMAGE=ghcr.io/yoisakiknd/omp-search-agent:v0.1.0
# BUN_VERSION=1.3.14
# Optional: set this only when users must also be members of a channel.
# TELEGRAM_CHANNEL_ID=-1001234567890
TELEGRAM_DISCUSSION_GROUP_ID=-1001234567891
OMP_MODEL=provider/model-id
# Add the API keys required by the selected model and search provider.
# BRAVE_API_KEY=
# TAVILY_API_KEY=
OMP_SEARCH_PROVIDER=auto
# SEARCH_MIN_SOURCES=6
# ANSWER_TARGET_CHARS=1400
# QUERY_TIMEOUT_MS=120000
# INSTANCE_LEASE_MS=90000
# JOB_RETENTION_DAYS=7
# ORPHAN_MEDIA_GRACE_HOURS=24
# HEALTH_STALE_MS=120000
DATA_DIR=./data
LOG_LEVEL=info
# MAX_TOTAL_IMAGE_BYTES=20971520
# Answer body rendering (reference URLs are sent as Telegram text).
# TYPST_PPI=160
# TYPST_MAX_CHARS=18000
# TYPST_MAX_PAGES=10
